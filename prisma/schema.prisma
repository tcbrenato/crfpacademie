generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  nom           String
  email         String    @unique
  telephone     String?
  motDePasse    String
  role          String    @default("membre")
  profil        String    @default("etudiant")
  points        Int       @default(0)
  niveau        Int       @default(1)
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  inscriptions  Inscription[]
  posts         Post[]
  commentaires  Commentaire[]
  achats        Achat[]
  badges        UserBadge[]
}

model Cours {
  id            String    @id @default(cuid())
  titre         String
  description   String
  categorie     String
  niveau        String
  duree         String
  prix          Float     @default(0)
  gratuit       Boolean   @default(false)
  image         String?
  videoUrl      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  modules       Module[]
  inscriptions  Inscription[]
}

model Module {
  id            String    @id @default(cuid())
  titre         String
  description   String?
  videoUrl      String?
  duree         String?
  ordre         Int
  coursId       String
  cours         Cours     @relation(fields: [coursId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
}

model Inscription {
  id            String    @id @default(cuid())
  userId        String
  coursId       String
  progression   Int       @default(0)
  termine       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cours         Cours     @relation(fields: [coursId], references: [id], onDelete: Cascade)

  @@unique([userId, coursId])
}

model Post {
  id            String    @id @default(cuid())
  titre         String
  contenu       String
  categorie     String
  likes         Int       @default(0)
  userId        String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentaires  Commentaire[]
}

model Commentaire {
  id            String    @id @default(cuid())
  contenu       String
  userId        String
  postId        String
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Evenement {
  id              String    @id @default(cuid())
  titre           String
  description     String
  type            String
  date            DateTime
  heure           String
  lieu            String
  intervenant     String
  roleIntervenant String
  places          Int
  inscrits        Int       @default(0)
  gratuit         Boolean   @default(true)
  prix            Float     @default(0)
  createdAt       DateTime  @default(now())
}

model Produit {
  id              String    @id @default(cuid())
  titre           String
  description     String
  categorie       String
  prix            Float     @default(0)
  gratuit         Boolean   @default(false)
  fichierUrl      String?
  telechargements Int       @default(0)
  note            Float     @default(0)
  vendeurNom      String
  createdAt       DateTime  @default(now())

  achats          Achat[]
}

model Achat {
  id            String    @id @default(cuid())
  userId        String
  produitId     String
  montant       Float
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  produit       Produit   @relation(fields: [produitId], references: [id], onDelete: Cascade)
}

model Badge {
  id            String    @id @default(cuid())
  titre         String
  description   String
  couleur       String
  condition     String

  users         UserBadge[]
}

model UserBadge {
  id            String    @id @default(cuid())
  userId        String
  badgeId       String
  obtenuLe      DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge         Badge     @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}